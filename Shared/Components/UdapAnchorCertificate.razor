<InputFile id="fileInput" OnChange="UploadFilesAsync" hidden />

<InputFile id="anchorFileInput" OnChange="UploadFilesAsync" hidden/>

<MudCard Class="pa-2 ma-2" Elevation="0">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Align="Align.End">Choose Trust Anchor Certificate.</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardActions>
        <MudStack Row="true" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Style="width: 100%">
            <MudFab HtmlTag="label"
                    Size="Size.Small"
                    Color="@AnchorLoadedColor"
                    StartIcon="@AppState.CertificateIcon"
                    Label="Upload"
                    Title="Upload Anchor Certificate"
                    IconSize="Size.Small"
                    for="anchorFileInput"/>
            <MudMenu Label="Load Pre-packaged Anchor"
                     StartIcon="@AppState.CertificateIcon"
                     Color="@PrePackagedAnchorLoadedColor"
                     Size="Size.Small"
                     Variant="Variant.Filled">
                @foreach (var anchor in _prePackagedAnchors)
                {
                    <MudMenuItem OnClick="@(() => LoadPrePackagedAnchor(anchor))" Title="@anchor.Description">@anchor.Name</MudMenuItem>
                }
            </MudMenu>
        </MudStack>
    </MudCardActions>
    <MudCardContent>
        @if (!string.IsNullOrEmpty(AppState.UdapAnchorCertificateInfo?.DistinguishedName) ||
             !string.IsNullOrEmpty(AppState.UdapAnchorCertificateInfo?.Thumbprint))
        {
            <MudItem xs="12">
                <MudText Typo="Typo.body2">@AppState.UdapAnchorCertificateInfo?.DistinguishedName</MudText>
            </MudItem>

            <MudItem xs="12">
                <MudText Typo="Typo.caption"> Thumbprint (sha1) </MudText>
                <MudText Typo="Typo.body2">@AppState.UdapAnchorCertificateInfo?.Thumbprint </MudText>
            </MudItem>
        }
    </MudCardContent>
</MudCard>
