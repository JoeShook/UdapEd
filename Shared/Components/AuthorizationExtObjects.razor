<MudCard Class="pa-2 ma-2" Elevation="3" >
    <MudCardContent>
        <MudGrid>
            <MudItem lg="6" md="12">
                <div @ref="_leftColumnRef">
                    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6"
                             ActivePanelIndexChanged="OnTabChanged"
                             TabHeaderClass="text-transform-none">
                        @if (OperationType == AuthExtObjectOperationType.Auth)
                        {
                            <MudTabPanel Text="hl7-b2b">
                                <Hl7B2BForm @ref="_hl7B2BForm" OnUpdateEditor="HandleUpdateEditor" OperationType="OperationType"/>
                            </MudTabPanel>
                        }
                        <MudTabPanel Text="hl7-b2b for TEFCA">
                            <Hl7B2BTefcaForm @ref="_hl7B2BTefcaForm" OnUpdateEditor="HandleUpdateEditor" OperationType="OperationType"/>
                        </MudTabPanel>
                        @if (OperationType == AuthExtObjectOperationType.Auth)
                        {
                            <MudTabPanel Text="hl7-b2b-user">
                                <Hl7B2BUserForm @ref="_hl7B2BUserForm" OnUpdateEditor="HandleUpdateEditor" OperationType="OperationType"/>
                            </MudTabPanel>
                        }
                        @if (OperationType == AuthExtObjectOperationType.Auth)
                        {
                            <MudTabPanel Text="tefca_ias">
                                <TefcaIasForm @ref="_tefcaIasForm" OnUpdateEditor="HandleUpdateEditor" OperationType="OperationType"/>
                            </MudTabPanel>
                        }
                    </MudTabs>
                </div>
            </MudItem>
            <MudItem lg="6" md="12">
                <MudGrid Justify="Justify.FlexEnd">
                    <MudItem>
                        <MudButton Class="ma-2" Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="SaveChanges">Save Custom Edits</MudButton>
                    </MudItem>
                </MudGrid>
                <div style="height: @(_editorHeight)px; min-height: 300px;">
                    <StandaloneCodeEditor @ref="_editor" Id="authExtObjectEditor"
                                          ConstructionOptions="EditorOptions"
                                          OnDidInit="EditorOnDidInit" />
                </div>
            </MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>